# Vorlage — echte Werte in .env (nicht committen).
# Lokal: podman-Postgres (siehe README). Produktion: gehostete DB (Vercel Postgres / Neon).
DATABASE_URL="postgresql://BENUTZER:PASSWORT@HOST:5432/DATENBANK?schema=public"

# --- Auth (Admin) ---
# Zufälliges Secret erzeugen:  openssl rand -base64 33
AUTH_SECRET="CHANGE_ME"
# Erster Admin-Benutzer wird beim Seed hieraus angelegt (Passwort wird als bcrypt-Hash gespeichert).
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="CHANGE_ME"

# --- Bild-Upload (Cloudflare R2, S3-kompatibel) ---
# Einrichtung Schritt für Schritt: siehe docs/r2-setup.md
# Solange diese leer sind, ist der Datei-Upload deaktiviert (Bilder dann per URL eintragen).
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# Öffentliche Basis-URL des Buckets (r2.dev-Adresse oder eigene Domain), ohne Slash am Ende.
R2_PUBLIC_BASE_URL=""
